@page "/device"
@inject IAssetService AssetService
@inject ILocalFolderService LocalFolderService
@inject IPendingAssetsProvider PendingAssetsProvider
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Mi Dispositivo - PhotoHub</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}

<div class="page-pad">
    <MudText Typo="Typo.h5" Class="mb-4">Mi Dispositivo</MudText>

    @if (!_loading)
    {
        @if (string.IsNullOrWhiteSpace(_folderName))
        {
            <EmptyState Icon="@Icons.Material.Filled.FolderOff"
                        Title="No hay ninguna carpeta seleccionada"
                        Description="Ve a Configuración → Dispositivo para seleccionar la carpeta donde están tus fotos.">
                <Actions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="@(() => Navigation.NavigateTo("/settings/device"))">
                        Configurar carpeta
                    </MudButton>
                </Actions>
            </EmptyState>
        }
        else
        {
            @* ── Header: carpeta + re-escanear ──────────────────────────── *@
            <MudPaper Class="d-flex align-center gap-3 px-4 py-3 mb-4" Elevation="0"
                      Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" />
                <div class="flex-grow-1 min-width-0">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Carpeta analizada</MudText>
                    <MudText Typo="Typo.body2" Style="word-break: break-all;">@_folderName</MudText>
                </div>
                <MudTooltip Text="Re-escanear">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   Disabled="@_loading"
                                   OnClick="@(async () => await LoadDeviceAssetsAsync())" />
                </MudTooltip>
            </MudPaper>

            @* ── Permiso denegado ─────────────────────────────────────── *@
            @if (_permissionDenied)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-4">
                    Permiso de lectura denegado. Pulsa el botón para volver a solicitarlo.
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="RetryPermissionAsync" Class="ml-2">
                        Solicitar permiso
                    </MudButton>
                </MudAlert>
            }

            @* ── Alerta de pendientes ─────────────────────────────────── *@
            @if (_assets.Count > 0 && !_uploadingAll)
            {
                <MudPaper Class="mb-4 pa-4" Elevation="0"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <div class="d-flex align-center gap-3 mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" Size="Size.Small" />
                        <div>
                            <MudText Typo="Typo.body2" Class="font-weight-medium">
                                @_assets.Count @(_assets.Count == 1 ? "foto pendiente" : "fotos pendientes") de subir
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Se subirán al servidor para su indexación
                            </MudText>
                        </div>
                    </div>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               FullWidth="true"
                               OnClick="UploadAllAsync">
                        Subir todas
                    </MudButton>
                </MudPaper>
            }

            @* ── Progreso de subida ──────────────────────────────────── *@
            @if (_uploadingAll)
            {
                <MudPaper Class="mb-4 pa-4" Elevation="0"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <div class="d-flex align-center gap-3 mb-2">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="flex-shrink-0" />
                        <MudText Typo="Typo.body2" Class="font-weight-medium flex-grow-1">@_uploadMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelUpload" Size="Size.Small">
                            Cancelar
                        </MudButton>
                    </div>
                    <MudProgressLinear Color="Color.Primary" Value="@_uploadProgress" Rounded="true" Class="mb-2" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @_uploadCurrent de @_uploadTotal subidas
                        @if (_uploadSuccessful > 0 || _uploadFailed > 0)
                        {
                            <span> · @_uploadSuccessful exitosas@(_uploadFailed > 0 ? $", {_uploadFailed} fallidas" : "")</span>
                        }
                    </MudText>
                </MudPaper>
            }

            @* ── Grid de assets ──────────────────────────────────────── *@
            @if (_groupedAssets.Count > 0)
            {
                @foreach (var group in _groupedAssets)
                {
                    <div class="mb-6">
                        <MudText Typo="Typo.body2" Class="device-date-header">@group.Key</MudText>
                        <MudGrid Spacing="1">
                            @foreach (var asset in group.Value)
                            {
                                <MudItem xs="4" sm="3" md="2" lg="2" xl="1">
                                    <AssetCard Asset="@asset" OnAssetClick="OpenAsset" />
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                }
            }
            else if (!_loading && !_permissionDenied)
            {
                <EmptyState Icon="@Icons.Material.Filled.CheckCircle"
                            Title="Todo sincronizado"
                            Description="@($"No hay archivos nuevos en «{_folderName}»")" />
            }
        }
    }
</div>

<style>
    .device-date-header {
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        text-transform: capitalize;
        padding: 0 4px 6px 4px;
    }

    @@media (max-width: 599.98px) {
        .device-date-header {
            font-size: 0.78rem !important;
        }
    }
</style>

@code {
    private List<TimelineItem> _assets = new();
    private Dictionary<string, List<TimelineItem>> _groupedAssets = new();
    private bool _loading = true;
    private bool _permissionDenied;
    private string _folderName = "";

    private bool _uploadingAll;
    private string _uploadMessage = "";
    private double _uploadProgress;
    private int _uploadCurrent;
    private int _uploadTotal;
    private int _uploadSuccessful;
    private int _uploadFailed;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            _folderName = await LocalFolderService.GetStoredFolderNameAsync() ?? "";
            if (!string.IsNullOrWhiteSpace(_folderName))
                await LoadDeviceAssetsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDeviceAssetsAsync()
    {
        try
        {
            _loading = true;
            _permissionDenied = false;
            StateHasChanged();

            _assets = await PendingAssetsProvider.GetPendingAssetsAsync();

            if (_assets.Count == 0)
            {
                // Si no hay assets y hay carpeta configurada, puede ser falta de permiso
                var hasPermission = await LocalFolderService.RequestPermissionAsync();
                if (!hasPermission)
                {
                    _permissionDenied = true;
                }
                else
                {
                    _assets = await PendingAssetsProvider.GetPendingAssetsAsync();
                }
            }

            GroupAssets();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al analizar la carpeta: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RetryPermissionAsync()
    {
        var granted = await LocalFolderService.RequestPermissionAsync();
        if (granted)
            await LoadDeviceAssetsAsync();
        else
            Snackbar.Add("Permiso denegado por el usuario", Severity.Warning);
    }

    private void GroupAssets()
    {
        _groupedAssets = _assets
            .OrderByDescending(a => a.ModifiedDate)
            .GroupBy(a => a.ModifiedDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES")))
            .ToDictionary(
                g => char.ToUpper(g.Key[0]) + g.Key[1..],
                g => g.ToList());
    }

    private void OpenAsset(TimelineItem asset)
    {
        // Los assets locales no tienen página de detalle en el servidor todavía.
    }

    private async Task UploadAllAsync()
    {
        if (_assets.Count == 0) return;

        _uploadingAll = true;
        _uploadTotal = _assets.Count;
        _uploadCurrent = 0;
        _uploadSuccessful = 0;
        _uploadFailed = 0;
        _uploadProgress = 0;
        _uploadMessage = "Iniciando subida...";
        _cts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            var toUpload = _assets.ToList();

            foreach (var asset in toUpload)
            {
                _cts.Token.ThrowIfCancellationRequested();

                _uploadMessage = $"Subiendo {asset.FileName}…";
                StateHasChanged();

                try
                {
                    var bytes = await LocalFolderService.ReadFileBytesAsync(asset.FullPath);
                    if (bytes == null || bytes.Length == 0)
                    {
                        _uploadFailed++;
                    }
                    else
                    {
                        using var stream = new MemoryStream(bytes);
                        var result = await AssetService.UploadAssetAsync(asset.FileName, stream, _cts.Token);
                        if (result != null)
                        {
                            _uploadSuccessful++;
                            _assets.Remove(asset);
                        }
                        else
                        {
                            _uploadFailed++;
                        }
                    }
                }
                catch (OperationCanceledException)
                {
                    throw;
                }
                catch
                {
                    _uploadFailed++;
                }

                _uploadCurrent++;
                _uploadProgress = (double)_uploadCurrent / _uploadTotal * 100;
                StateHasChanged();
            }

            GroupAssets();

            Snackbar.Add(
                $"Subida completada: {_uploadSuccessful} exitosas{(_uploadFailed > 0 ? $", {_uploadFailed} fallidas" : "")}",
                _uploadFailed > 0 ? Severity.Warning : Severity.Success);
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Subida cancelada", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error durante la subida: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploadingAll = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private void CancelUpload() => _cts?.Cancel();

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
