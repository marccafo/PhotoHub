@page "/utilities/large-files"
@inject IAssetService AssetService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Archivos grandes - PhotoHub</PageTitle>

<div class="page-pad">
    <div class="d-flex align-center gap-3 mb-4 flex-wrap">
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Navigation.NavigateTo("/utilities"))">
            Utilidades
        </MudButton>
        <MudText Typo="Typo.h5">Archivos grandes</MudText>
    </div>

<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Los @_count elementos que más espacio ocupan en tu biblioteca.
</MudText>

<div class="d-flex align-center gap-3 mb-4 flex-wrap">
    <MudSelect T="int" Value="_count" ValueChanged="OnCountChanged" Label="Mostrar" Variant="Variant.Outlined"
               Style="width:120px;" Dense="true">
        <MudSelectItem Value="25">25</MudSelectItem>
        <MudSelectItem Value="50">50</MudSelectItem>
        <MudSelectItem Value="100">100</MudSelectItem>
        <MudSelectItem Value="200">200</MudSelectItem>
    </MudSelect>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="LoadAsync" Disabled="_loading">
        Actualizar
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_items.Count == 0)
{
    <MudAlert Severity="Severity.Info">No se encontraron archivos.</MudAlert>
}
else
{
    <MudTable Items="_items" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
              Class="mb-4" RowStyleFunc="@((_, _) => "cursor:pointer")">
        <HeaderContent>
            <MudTh Style="width:56px"></MudTh>
            <MudTh>Nombre</MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="@(new Func<TimelineItem,object>(x => x.FileSize))" InitialDirection="SortDirection.Descending">
                    Tamaño
                </MudTableSortLabel>
            </MudTh>
            <MudTh>Fecha</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <div style="width:44px;height:44px;border-radius:4px;overflow:hidden;background:#111;">
                    <img src="@context.ThumbnailUrl" alt="@context.FileName"
                         style="width:100%;height:100%;object-fit:cover;"
                         onerror="this.style.display='none'" />
                </div>
            </MudTd>
            <MudTd>
                <MudLink Href="@($"/asset/{context.Id}?returnTo=utilities/large-files")" Underline="Underline.None">
                    <MudText Typo="Typo.body2" Style="word-break:break-all;">@context.FileName</MudText>
                </MudLink>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                         Color="@(context.Type == "Video" ? Color.Secondary : Color.Default)">
                    @context.Type
                </MudChip>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2"><strong>@context.FileSizeFormatted</strong></MudText>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.DisplayDate</MudText>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small"
                               Href="@($"/asset/{context.Id}?returnTo=utilities/large-files")" Title="Ver detalle" />
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudText Typo="Typo.caption" Class="mud-text-secondary">
        Total mostrado: @FormatBytes(_items.Sum(i => i.FileSize))
    </MudText>
}
</div>

@code {
    private List<TimelineItem> _items = new();
    private bool _loading;
    private int _count = 50;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnCountChanged(int value)
    {
        _count = value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _items = await AssetService.GetLargeFilesAsync(_count);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1) { order++; len /= 1024; }
        return $"{len:0.##} {sizes[order]}";
    }
}
