@if (_yearGroups.Any())
{
    <div class="memories-widget">
        <div class="memories-header">
            <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" Class="memories-icon" />
            <div class="memories-header-text">
                <span class="memories-title">Recuerdos</span>
                <span class="memories-date">@_dateLabel</span>
            </div>
        </div>

        <div class="memories-cards">
            @foreach (var group in _yearGroups)
            {
                var yearsAgo = DateTime.Today.Year - group.Key;
                var heroAsset = group.Value.First();
                var stripAssets = group.Value.Skip(1).Take(10).ToList();

                <div class="memories-card">
                    <div class="memories-card-hero" @onclick="() => OnThumbClick.InvokeAsync(heroAsset)">
                        <img src="@heroAsset.ThumbnailUrl" alt="memory" loading="lazy" />

                        <div class="memories-card-count-pill">
                            @group.Value.Count @(group.Value.Count == 1 ? "foto" : "fotos")
                        </div>

                        @if (heroAsset.Type == "VIDEO")
                        {
                            <div class="memories-video-badge">
                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                            </div>
                        }

                        <div class="memories-card-overlay">
                            <span class="memories-card-years-ago">Hace @yearsAgo @(yearsAgo == 1 ? "año" : "años")</span>
                            <span class="memories-card-year">@group.Key</span>
                        </div>
                    </div>

                    @if (stripAssets.Any())
                    {
                        <div class="memories-card-strip">
                            @foreach (var asset in stripAssets)
                            {
                                <div class="memories-card-thumb" @onclick="() => OnThumbClick.InvokeAsync(asset)">
                                    <img src="@asset.ThumbnailUrl" alt="memory" loading="lazy" />
                                    @if (asset.Type == "VIDEO")
                                    {
                                        <div class="memories-video-badge memories-video-sm">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    /* ── Widget container ── */
    .memories-widget {
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    /* ── Header ── */
    .memories-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
        padding: 0 2px;
    }

    .memories-icon {
        color: var(--mud-palette-primary);
        flex-shrink: 0;
    }

    .memories-header-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .memories-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        letter-spacing: 0.01em;
    }

    .memories-date {
        font-size: 0.72rem;
        color: var(--mud-palette-text-secondary);
        text-transform: capitalize;
    }

    /* ── Cards list ── */
    .memories-cards {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* ── Individual card ── */
    .memories-card {
        border-radius: 16px;
        overflow: hidden;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }

    /* ── Hero section ── */
    .memories-card-hero {
        position: relative;
        width: 100%;
        height: 200px;
        cursor: pointer;
        overflow: hidden;
        background: #1a1a1a;
    }

    .memories-card-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .memories-card-hero:hover img,
    .memories-card-hero:active img {
        transform: scale(1.03);
    }

    /* Gradient overlay */
    .memories-card-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 32px 14px 12px;
        background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.35) 60%, transparent 100%);
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
    }

    .memories-card-years-ago {
        font-size: 0.85rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 0.01em;
        text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }

    .memories-card-year {
        font-size: 0.78rem;
        font-weight: 400;
        color: rgba(255,255,255,0.7);
        text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }

    /* Photo count pill */
    .memories-card-count-pill {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.9);
        font-size: 0.7rem;
        font-weight: 500;
        padding: 3px 9px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.12);
        letter-spacing: 0.02em;
        z-index: 1;
    }

    /* Video badge */
    .memories-video-badge {
        position: absolute;
        bottom: 44px;
        right: 10px;
        color: white;
        filter: drop-shadow(0 0 3px rgba(0,0,0,0.7));
        z-index: 1;
    }

    .memories-video-sm {
        bottom: 4px;
        right: 4px;
    }

    /* ── Mini strip ── */
    .memories-card-strip {
        display: flex;
        gap: 2px;
        overflow-x: auto;
        scrollbar-width: none;
        padding: 2px 0 0;
        background: rgba(0,0,0,0.2);
    }

    .memories-card-strip::-webkit-scrollbar {
        display: none;
    }

    .memories-card-thumb {
        flex-shrink: 0;
        width: 64px;
        height: 64px;
        overflow: hidden;
        cursor: pointer;
        position: relative;
        background: #2a2a2a;
    }

    .memories-card-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity 0.15s;
    }

    .memories-card-thumb:hover img,
    .memories-card-thumb:active img {
        opacity: 0.8;
    }
</style>

@code {
    [Parameter] public EventCallback<TimelineItem> OnThumbClick { get; set; }
    [Inject] private IAssetService AssetService { get; set; } = null!;

    private Dictionary<int, List<TimelineItem>> _yearGroups = new();
    private string _dateLabel = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        _dateLabel = today.ToString("d 'de' MMMM", new System.Globalization.CultureInfo("es-ES"));

        var items = await AssetService.GetMemoriesAsync();
        _yearGroups = items
            .GroupBy(a => a.CreatedDate.Year)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }
}
