# Copia este archivo como .env y rellena los valores

# PostgreSQL (nombre de BD y usuario tienen valores por defecto si se omiten)
POSTGRES_DB=photohub
POSTGRES_USER=photohub_user
POSTGRES_PASSWORD=cambia_esto_por_password_seguro

# Clave JWT - debe ser larga (mínimo 32 caracteres) y aleatoria
JWT_KEY=cambia_esto_por_clave_jwt_muy_larga_y_aleatoria_minimo_32_chars

# Ruta en el NAS donde están tus fotos
# ZimaOS: las rutas suelen ser /DATA/Media/Photos o similar
ASSETS_PATH=/DATA/Media/Photos

# Redirigir HTTP a HTTPS (desactivado por defecto)
# Actívalo solo si tienes HTTPS configurado en el propio contenedor (no en un proxy)
HTTPS_REDIRECT=false
